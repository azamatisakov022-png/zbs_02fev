# ═══════════════════════════════════════════════════════════════════════════
# Пример environment-переменных для production-развёртывания.
# Скопируйте этот файл в `.env` и заполните реальными значениями.
# НЕ коммитьте `.env` в git — он в .gitignore.
# ═══════════════════════════════════════════════════════════════════════════

# ── База данных PostgreSQL ──────────────────────────────────────────────
POSTGRES_DB=eco_operator
POSTGRES_USER=eco
# Сгенерируйте сильный пароль: openssl rand -base64 24
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── JWT secret для backend ──────────────────────────────────────────────
# ОБЯЗАТЕЛЬНО сгенерируйте новый: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_BASE64_AT_LEAST_64_BYTES

# ── MinIO (S3-совместимое хранилище для документов и фото) ──────────────
MINIO_ROOT_USER=minioadmin
# Сгенерируйте: openssl rand -base64 24
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD
MINIO_BUCKET=eco-operator

# ── HTTP-порт frontend nginx (наружу) ───────────────────────────────────
HTTP_PORT=80

# ── URL backend для frontend (по умолчанию относительный путь /api/v1) ──
FRONTEND_API_URL=/api/v1

# ── Внешние интеграции (если есть, иначе оставить пустыми) ──────────────
# TAX_SERVICE_URL=https://tax.example.gov.kg/api/v1
# TAX_SERVICE_API_KEY=...
# CUSTOMS_SERVICE_URL=https://customs.example.gov.kg/api/v1
# CUSTOMS_SERVICE_API_KEY=...
# BANK_SERVICE_URL=https://bank.example.kg/api/v1
# BANK_SERVICE_API_KEY=...
